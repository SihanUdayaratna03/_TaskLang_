TASK backupDB {
  RUN "backup.sh";
  EVERY DAY AT 02:00;
}

TASK processData {
  RUN "process.py";
  AFTER backupDB;
  IF success;
}

TASK generateReport {
  RUN "report.py";
  AFTER processData;
  IF success;
}

TASK weeklyCleanup {
  RUN "cleanup.sh";
  EVERY WEEK ON SUNDAY AT 03:00;
}

TASK dailyNotify {
  RUN "notify.sh";
  EVERY DAY AT 07:00;
}
